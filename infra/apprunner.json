{
  "ServiceName": "ecosphere-app",
  "SourceConfiguration": {
    "AuthenticationConfiguration": {
      "AccessRoleArn": "arn:aws:iam::961308088417:role/ecosphere-apprunner-ecr-access"
    },
    "ImageRepository": {
      "ImageIdentifier": "961308088417.dkr.ecr.us-east-1.amazonaws.com/ecosphere-app:latest",
      "ImageRepositoryType": "ECR",
      "ImageConfiguration": {
        "Port": "4000",
        "RuntimeEnvironmentVariables": {
          "NODE_ENV": "production",
          "PORT": "4000",
          "CLIENT_ORIGIN": "*",
          "JWT_SECRET": "ecosphere-prod-jwt-secret-hackathon-2026-odoo",
          "ACCESS_TOKEN_EXPIRES_IN": "15m",
          "REFRESH_TOKEN_TTL_DAYS": "7",
          "BCRYPT_ROUNDS": "10",
          "DEMO_EMAIL": "demo@ecosphere.com",
          "DEMO_PASSWORD": "EcoSphere@2024"
        }
      }
    }
  },
  "InstanceConfiguration": {
    "Cpu": "1024",
    "Memory": "2048"
  },
  "HealthCheckConfiguration": {
    "Protocol": "HTTP",
    "Path": "/api/health",
    "Interval": 10,
    "Timeout": 5,
    "HealthyThreshold": 1,
    "UnhealthyThreshold": 5
  }
}
